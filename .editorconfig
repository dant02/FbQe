root = true

[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.{sln,slnx,vcxproj,vcxproj.filters,csproj,props,targets,yml,yaml,json,sql,bat,cmd,ps1,md}]
charset = utf-8

[*.cpp]
indent_style = space
indent_size = 4

[*.h]
indent_style = space
indent_size = 4

[*.cs]
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false
